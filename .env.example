# ─────────────────────────────────────────────────────────────────────────────
# Venice on-chain analyst — environment configuration
# Copy this file to `.env.local` (or `.env`) and fill in values. NEVER commit it.
#
# This agent authenticates to Venice EXCLUSIVELY via x402 wallet auth.
# Inference AND Crypto RPC are paid for from the agent wallet — there is no
# API-key path by design.
# ─────────────────────────────────────────────────────────────────────────────

# ── x402 wallet auth (the only auth path) ────────────────────────────────────
# Private key of the wallet that pays for inference + RPC (Base). 0x + 64 hex.
# Generate a fresh throwaway wallet:  npm run keygen
# Prefer the encrypted keystore below over putting a raw key here.
WALLET_PRIVATE_KEY=

# Optional: load the key from an encrypted keystore instead of the raw env var.
# If set, the app decrypts keystore.json with this passphrase at startup.
# Create one with:  npm run encrypt-key
KEYSTORE_PATH=
KEYSTORE_PASSPHRASE=

# ── Models ───────────────────────────────────────────────────────────────────
# The E2EE-capable model used for the *private* analysis step.
E2EE_MODEL=e2ee-qwen3-5-122b-a10b
# A fast model used for cheap/non-sensitive helper calls (optional).
FAST_MODEL=kimi-k2-5

# ── Crypto RPC ───────────────────────────────────────────────────────────────
# Default network slug for on-chain reads. See /api-reference/endpoint/crypto/networks.
DEFAULT_NETWORK=base-mainnet

# ── Venice API base ──────────────────────────────────────────────────────────
VENICE_BASE_URL=https://api.venice.ai/api/v1
